class Solution {
    public String reverseWords(String s) {
            StringBuilder bd = new StringBuilder();
        String[] words = s.trim().split("\\s+");
        
        for (int i = words.length - 1; i >= 0; i--) {
            bd.append(words[i]);
            if (i > 0) {
                bd.append(" ");
            }

        }
            return bd.toString();

    }
}
